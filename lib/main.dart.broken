              return Container(
                width: double.infinity,
                padding: const EdgeInsets.all(8.0),
                color: Colors.grey.shade700,
                child: Row(
                  children: [
                    Expanded(
                      child: Text(
                        _buildFilterStatusText(filter),
                        style: const TextStyle(
                          color: Colors.white,
                          fontSize: 12,
                        ),
                      ),
